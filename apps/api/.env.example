# ─── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=reservation_seats
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# ─── Auth (Google OAuth) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=90d

# ─── Frontend URL (for redirects & CORS) ──────────────────
FRONTEND_URL=http://localhost:5173

# ─── Payment (Napas / VNPay Sandbox) ──────────────────────
NAPAS_TMN_CODE=
NAPAS_HASH_SECRET=
NAPAS_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
NAPAS_RETURN_URL=http://localhost:3000/payments/return
NAPAS_IPN_URL=http://localhost:3000/payments/ipn

# ─── Seat Hold ─────────────────────────────────────────────
SEAT_HOLD_DURATION_SECONDS=300
